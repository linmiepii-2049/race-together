[node name="BtnJoin" type="Button" parent="Root/Panel/Margin/VBox"]
layout_mode = 2
text = "加入房間"

[node name="BtnSeal" type="Button" parent="Root/Panel/Margin/VBox"]
layout_mode = 2
text = "封房（房主，準備開玩）"

[node name="BtnBeginNet" type="Button" parent="Root/Panel/Margin/VBox"]
layout_mode = 2
