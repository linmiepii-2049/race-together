[node name="UrlRow" type="HBoxContainer" parent="Root/Panel/Margin/VBox"]
layout_mode = 2

[node name="UrlLabel" type="Label" parent="Root/Panel/Margin/VBox/UrlRow"]
layout_mode = 2
