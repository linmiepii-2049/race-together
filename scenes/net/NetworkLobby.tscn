[node name="CodeRow" type="HBoxContainer" parent="Root/Panel/Margin/VBox"]
layout_mode = 2

[node name="CodeLabel" type="Label" parent="Root/Panel/Margin/VBox/CodeRow"]
layout_mode = 2
text = "房碼"

[node name="CodeField" type="LineEdit" parent="Root/Panel/Margin/VBox/CodeRow"]
